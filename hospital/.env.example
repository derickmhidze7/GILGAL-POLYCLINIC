# =============================================
#  ENVIRONMENT VARIABLES — GILGAL POLYCLINIC
# =============================================

# --- PostgreSQL container initialisation ---
POSTGRES_DB=gilgal_polyclinic
POSTGRES_USER=gilgal_user
POSTGRES_PASSWORD=

# --- Database (required for all profiles) ---
DB_URL=jdbc:postgresql://gilgal_postgres:5432/gilgal_polyclinic
DB_USERNAME=gilgal_user
DB_PASSWORD=YourStrongPasswordHere

# --- JWT Signing Key ---
JWT_SECRET=PASTE_YOUR_JWT_SECRET_HERE

# --- Admin seed account ---
ADMIN_EMAIL=admin@gilgalpolyclinic.com
ADMIN_PASSWORD=YourAdminPasswordHere

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=prod
