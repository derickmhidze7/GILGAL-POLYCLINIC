# =============================================
#  ENVIRONMENT VARIABLES — Reference Template
#  Copy this to .env (gitignored) and fill in real values.
#  For local dev: set these in your shell or IDE run configuration.
#  For production: inject via server/container environment.
# =============================================

# --- Database (required for all profiles) ---
DB_URL=jdbc:postgresql://localhost:5432/adags_hospital
DB_USERNAME=adags_user
DB_PASSWORD=root

# --- JWT Signing Key (required for production) ---
# Generate a strong random secret: at least 64 characters, base64-encoded.
# Example (Linux/Mac): openssl rand -base64 64
# In dev, the application.properties fallback default is used if this is unset.
JWT_SECRET=bXlTdXBlclNlY3JldEtlRm9ySG9zcGl0YWxNYW5hZ2VtZW50U3lzdGVtQURBR1MxMjM0NTY3ODkw

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=dev